<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/input_border.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <solid android:color="#F5F5F5" /> <!-- 示例浅灰，换成你的实际颜色值 -->

    <!-- 边框：1dp 宽度 + 灰色 -->
    <stroke
        android:width="1dp"
        android:color="#DDDDDD" /> <!-- 边框颜色，建议比背景色深 -->

    <!-- 圆角（可选，输入框通常需要轻微圆角） -->
    <corners android:radius="10dp" />
</shape>